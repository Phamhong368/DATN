{
  "name": "tms-monorepo",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "npm run dev -w backend & npm run dev -w frontend",
    "dev:backend": "npm run dev -w backend",
    "dev:frontend": "npm run dev -w frontend",
    "test": "npm run test:backend && npm run test:frontend",
    "test:backend": "npm run test -w backend",
    "test:frontend": "npm run test -w frontend",
    "test:integration": "npm run test:integration -w backend",
    "test:e2e": "npm run test:e2e -w frontend",
    "smoke": "npm run smoke -w backend",
    "smoke:backend": "npm run smoke -w backend",
    "benchmark:vrp": "npm run benchmark:vrp -w backend",
    "build": "npm run build -w frontend",
    "start": "npm run start -w backend"
  }
}
